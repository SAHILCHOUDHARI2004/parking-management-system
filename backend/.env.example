# Database connection string (PostgreSQL with pg8000 driver)
DATABASE_URL=postgresql+pg8000://username:password@localhost:5432/pms_db

# Secret key for JWT token encoding/decoding (should be a secure random hex string in production)
SECRET_KEY=your_secret_key_here

# JWT Algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiration time in minutes (default: 1440 minutes / 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend port (default: 5000)
PORT=5000

# CORS Allowed Origins (comma-separated list of origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
